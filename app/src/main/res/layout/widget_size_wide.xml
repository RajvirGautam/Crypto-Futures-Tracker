<?xml version="1.0" encoding="utf-8"?>
<!--
  WIDE layout — single coin with full-width chart (4×2+, 3×3+)
  Matches Binance-style card: header → sparkline → price → sub-info
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="8dp">

    <!-- Stubs for unused IDs -->
    <ImageView android:id="@+id/btnStars" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvSubtitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvSymbol2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvPrice2"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvChange2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/imgGraph2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvSymbol3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvPrice3"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvChange3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/imgGraph3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvSymbol4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvPrice4"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvChange4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/imgGraph4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- Row 1: [icon + name] ... [↻ time] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/circle_bg"
            android:src="@drawable/ic_btc"
            android:padding="6dp"
            android:scaleType="centerInside"/>

        <!-- Name column: BTC bold, Bitcoin / Tether subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/tvSymbol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BTC"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bitcoin / Tether"
                android:textColor="#71717A"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_refresh"
            android:drawablePadding="3dp"
            android:text="0:00"
            android:textColor="#606060"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Full-width sparkline chart with gradient fill -->
    <ImageView
        android:id="@+id/imgGraph"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.5"
        android:scaleType="fitXY"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"/>

    <!-- Giant price -->
    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:gravity="bottom|start"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="0.00"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="18sp"
        android:autoSizeMaxTextSize="48sp"/>

    <!-- Sub-info: [USDT] [+1,510.99 · 1.85%] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/tvQuote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USDT"
            android:textColor="#71717A"
            android:textSize="11sp"
            android:paddingEnd="6dp"/>

        <TextView
            android:id="@+id/tvChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00 · 0.00%"
            android:textColor="#10B981"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
