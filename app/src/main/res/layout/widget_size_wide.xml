<?xml version="1.0" encoding="utf-8"?>
<!--
  WIDE / MULTI-COIN layout — matches screenshots 4 & 5 (4×2+, 3×3+)
  Dark pill | 3 evenly-spaced coin columns: [BTC/USD | ETH/USD | CONFIGURED/USD]
  Each column: label on top, price middle, % change below | shared timestamp bottom-left
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Hidden single-coin stubs (IDs kept for WidgetUpdater compatibility) -->
    <ImageView android:id="@+id/imgLogo"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvName"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/imgGraph" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/btnStars" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- 3-column coin row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Column 1: BTC/USD (always) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSymbol"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|start"
                android:text="BTC/USD"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.6"
                android:gravity="center_vertical|start"
                android:text="0.00"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="28sp"/>

            <TextView
                android:id="@+id/tvChange"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="top|start"
                android:text="0.00%"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="11sp"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>
        </LinearLayout>

        <!-- Thin vertical divider (TextView, not View — View is unsupported in RemoteViews) -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <!-- Column 2: ETH/USD (always) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/tvSymbol2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|start"
                android:text="ETH/USD"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>

            <TextView
                android:id="@+id/tvPrice2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.6"
                android:gravity="center_vertical|start"
                android:text="0.00"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="28sp"/>

            <TextView
                android:id="@+id/tvChange2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="top|start"
                android:text="0.00%"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="11sp"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>
        </LinearLayout>

        <!-- Thin vertical divider (TextView, not View — View is unsupported in RemoteViews) -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <!-- Column 3: Configured coin (or BNB/USD fallback) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/tvSymbol3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|start"
                android:text="BNB/USD"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>

            <TextView
                android:id="@+id/tvPrice3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.6"
                android:gravity="center_vertical|start"
                android:text="0.00"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="28sp"/>

            <TextView
                android:id="@+id/tvChange3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="top|start"
                android:text="0.00%"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="11sp"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeMaxTextSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom row: timestamp left -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:drawableStart="@drawable/ic_refresh"
        android:drawablePadding="3dp"
        android:text="10:59 pm"
        android:textColor="#606060"
        android:textSize="9sp"
        android:gravity="start"/>

</LinearLayout>
