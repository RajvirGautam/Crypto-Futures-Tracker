<?xml version="1.0" encoding="utf-8"?>
<!--
  TWO COIN — two equal columns, each a mini single-coin design.
  Charts always visible, auto-size text makes it responsive at any size.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <!-- Stubs for unused coin slots (3 + 4) and legacy IDs -->
        <ImageView android:id="@+id/imgLogo"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvSubtitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvSymbol3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvPrice3"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvChange3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/imgGraph3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvSymbol4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvPrice4"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvChange4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/imgGraph4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvName"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/btnStars"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <!-- Two columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- ── Column 1 ── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="5dp">

                    <TextView
                        android:id="@+id/tvSymbol"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BTC"
                        android:textColor="#DDDDDD"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="8sp"
                        android:autoSizeMaxTextSize="14sp"/>

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_refresh"
                        android:drawablePadding="2dp"
                        android:text="0:56"
                        android:textColor="#444444"
                        android:fontFamily="sans-serif"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="10sp"/>
                </LinearLayout>

                <!-- Chart -->
                <ImageView
                    android:id="@+id/imgGraph"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.6"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <!-- Price + change -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.6"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="3dp">

                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="9sp"
                        android:autoSizeMaxTextSize="28sp"/>

                    <TextView
                        android:id="@+id/tvChange"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.6"
                        android:gravity="top|start"
                        android:text="USDT +0.00 · 0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <TextView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#1AFFFFFF"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"/>

            <!-- ── Column 2 ── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:id="@+id/tvSymbol2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ETH"
                        android:textColor="#DDDDDD"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="8sp"
                        android:autoSizeMaxTextSize="14sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgGraph2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.6"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.6"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp">

                    <TextView
                        android:id="@+id/tvPrice2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="9sp"
                        android:autoSizeMaxTextSize="28sp"/>

                    <TextView
                        android:id="@+id/tvChange2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.6"
                        android:gravity="top|start"
                        android:text="USDT +0.00 · 0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_github"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="rajvirgautam"
            android:textColor="#9A9A9A"
            android:textSize="8sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>
</FrameLayout>
