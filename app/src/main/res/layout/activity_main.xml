<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Active Contract -->
        <TextView
            android:text="Active Contract"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <AutoCompleteTextView
            android:id="@+id/etSymbol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search futures symbol (BTCUSDT, XRPUSDT)"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginVertical="12dp"/>

        <!-- Digit Selector -->
        <TextView
            android:text="Status Bar Digits Position"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <SeekBar
            android:id="@+id/seekDigits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"/>

        <TextView
            android:id="@+id/tvDigitPreview"
            android:text="Showing digits: ---"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Update Interval -->
        <TextView
            android:text="Update Interval"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup
            android:id="@+id/rgInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rb1s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1s"
                android:textColor="#FFFFFF"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb2s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2s"
                android:textColor="#FFFFFF"/>

            <RadioButton
                android:id="@+id/rb5s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5s"
                android:textColor="#FFFFFF"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnToggle"
            android:text="START SERVICE"
            android:layout_marginTop="24dp"
            android:backgroundTint="#1DB954"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvStatus"
            android:text="Service stopped"
            android:textColor="#FF5555"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>