<?xml version="1.0" encoding="utf-8"?>
<!-- FOUR COIN — 2×2 grid -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Stubs for legacy IDs -->
        <ImageView android:id="@+id/imgLogo"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvSubtitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvName"     android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/btnStars"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <!-- TOP ROW: coins 1 + 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Cell 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.8"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp">

                    <TextView
                        android:id="@+id/tvSymbol"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BTC"
                        android:textColor="#F4F4F4"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="14sp"/>

                    <TextView
                        android:id="@+id/tvTimeStub"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgGraph"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:scaleType="fitXY"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="2dp">

                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="18sp"/>

                    <TextView
                        android:id="@+id/tvChange"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.5"
                        android:gravity="top|start"
                        android:text="+0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="5sp"
                        android:autoSizeMaxTextSize="9sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Vertical divider -->
            <TextView android:layout_width="1dp" android:layout_height="match_parent"
                android:background="#1AFFFFFF"
                android:layout_marginTop="2dp" android:layout_marginBottom="2dp"/>

            <!-- Cell 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.8"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/tvSymbol2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ETH"
                        android:textColor="#F4F4F4"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="14sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgGraph2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:scaleType="fitXY"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp">

                    <TextView
                        android:id="@+id/tvPrice2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="18sp"/>

                    <TextView
                        android:id="@+id/tvChange2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.5"
                        android:gravity="top|start"
                        android:text="+0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="5sp"
                        android:autoSizeMaxTextSize="9sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Horizontal divider -->
        <TextView android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginStart="3dp" android:layout_marginEnd="3dp"/>

        <!-- BOTTOM ROW: coins 3 + 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Cell 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.8"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp">

                    <TextView
                        android:id="@+id/tvSymbol3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SOL"
                        android:textColor="#F4F4F4"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="14sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgGraph3"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:scaleType="fitXY"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="2dp">

                    <TextView
                        android:id="@+id/tvPrice3"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="18sp"/>

                    <TextView
                        android:id="@+id/tvChange3"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.5"
                        android:gravity="top|start"
                        android:text="+0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="5sp"
                        android:autoSizeMaxTextSize="9sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="1dp" android:layout_height="match_parent"
                android:background="#1AFFFFFF"
                android:layout_marginTop="2dp" android:layout_marginBottom="2dp"/>

            <!-- Cell 4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.8"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/tvSymbol4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BNB"
                        android:textColor="#F4F4F4"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="14sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgGraph4"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:scaleType="fitXY"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp">

                    <TextView
                        android:id="@+id/tvPrice4"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom|start"
                        android:text="0.00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="7sp"
                        android:autoSizeMaxTextSize="18sp"/>

                    <TextView
                        android:id="@+id/tvChange4"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.5"
                        android:gravity="top|start"
                        android:text="+0.00%"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="5sp"
                        android:autoSizeMaxTextSize="9sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:src="@drawable/ic_github"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="rajvirgautam"
            android:textColor="#8F8F8F"
            android:textSize="7sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="10dp"
        android:drawableStart="@drawable/ic_refresh"
        android:drawablePadding="3dp"
        android:text="0:56"
        android:textColor="#9C9C9C"
        android:fontFamily="sans-serif"
        android:textSize="8sp"
        android:gravity="center_vertical"/>
</FrameLayout>
