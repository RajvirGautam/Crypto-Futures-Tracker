<?xml version="1.0" encoding="utf-8"?>
<!-- FOUR COIN — 2×2 grid with prominent sparklines -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Stubs for legacy IDs -->
        <ImageView android:id="@+id/imgLogo"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvSubtitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvName"     android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/btnStars"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView  android:id="@+id/tvTime"     android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <!-- TOP ROW: coins 1 + 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Cell 1: BTC -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="3dp">

                <!-- Header: Symbol -->
                <TextView
                    android:id="@+id/tvSymbol"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical|start"
                    android:text="BTC"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="14sp"/>

                <!-- Chart -->
                <ImageView
                    android:id="@+id/imgGraph"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2.3"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <!-- Price + Change Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.2"
                    android:orientation="vertical"
                    android:paddingTop="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:orientation="horizontal"
                        android:gravity="bottom|center_vertical">

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|start"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="9sp"
                            android:autoSizeMaxTextSize="22sp"/>

                        <TextView
                            android:id="@+id/tvFunding"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="F +0.00%"
                            android:textColor="#22C55E"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="6sp"
                            android:autoSizeMaxTextSize="10sp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvChange"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top|start"
                        android:text="+0.00% · H: 0 · L: 0"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="9sp"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Vertical Divider -->
            <TextView android:layout_width="0.5dp" android:layout_height="match_parent"
                android:background="#20FFFFFF"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"/>

            <!-- Cell 2: XRP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="3dp"
                android:paddingEnd="6dp">

                <TextView
                    android:id="@+id/tvSymbol2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical|start"
                    android:text="XRP"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="14sp"/>

                <ImageView
                    android:id="@+id/imgGraph2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2.3"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.2"
                    android:orientation="vertical"
                    android:paddingTop="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:orientation="horizontal"
                        android:gravity="bottom|center_vertical">

                        <TextView
                            android:id="@+id/tvPrice2"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|start"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="9sp"
                            android:autoSizeMaxTextSize="22sp"/>

                        <TextView
                            android:id="@+id/tvFunding2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="F +0.00%"
                            android:textColor="#22C55E"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="6sp"
                            android:autoSizeMaxTextSize="10sp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvChange2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top|start"
                        android:text="+0.00% · H: 0 · L: 0"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="9sp"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="10sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Horizontal Divider -->
        <TextView android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#20FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <!-- BOTTOM ROW: coins 3 + 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Cell 3: SOL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="3dp">

                <TextView
                    android:id="@+id/tvSymbol3"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical|start"
                    android:text="SOL"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="14sp"/>

                <ImageView
                    android:id="@+id/imgGraph3"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2.3"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.2"
                    android:orientation="vertical"
                    android:paddingTop="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:orientation="horizontal"
                        android:gravity="bottom|center_vertical">

                        <TextView
                            android:id="@+id/tvPrice3"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|start"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="9sp"
                            android:autoSizeMaxTextSize="22sp"/>

                        <TextView
                            android:id="@+id/tvFunding3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="F +0.00%"
                            android:textColor="#22C55E"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="6sp"
                            android:autoSizeMaxTextSize="10sp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvChange3"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top|start"
                        android:text="+0.00% · H: 0 · L: 0"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="9sp"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Vertical Divider -->
            <TextView android:layout_width="0.5dp" android:layout_height="match_parent"
                android:background="#20FFFFFF"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"/>

            <!-- Cell 4: ETH -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="3dp"
                android:paddingEnd="6dp">

                <TextView
                    android:id="@+id/tvSymbol4"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical|start"
                    android:text="ETH"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="14sp"/>

                <ImageView
                    android:id="@+id/imgGraph4"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2.3"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.2"
                    android:orientation="vertical"
                    android:paddingTop="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:orientation="horizontal"
                        android:gravity="bottom|center_vertical">

                        <TextView
                            android:id="@+id/tvPrice4"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|start"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="9sp"
                            android:autoSizeMaxTextSize="22sp"/>

                        <TextView
                            android:id="@+id/tvFunding4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="F +0.00%"
                            android:textColor="#22C55E"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="6sp"
                            android:autoSizeMaxTextSize="10sp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvChange4"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top|start"
                        android:text="+0.00% · H: 0 · L: 0"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="9sp"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="6sp"
                        android:autoSizeMaxTextSize="10sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Username badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/ic_github"
            android:scaleType="fitCenter"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="rajvirgautam"
            android:textColor="#666666"
            android:textSize="7sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>
</FrameLayout>
