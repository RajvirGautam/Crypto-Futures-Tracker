<?xml version="1.0" encoding="utf-8"?>
<!--
  MEDIUM layout — matches screenshot 3 (3×2, 2×3, 4×2 single-coin)
  Dark pill | row: [BTC icon  SYMBOL/USD  %change] | row: [giant price | sparkline] | row: [time + refresh | gear]
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Multi-coin stubs -->
    <TextView  android:id="@+id/tvSymbol2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvPrice2"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvChange2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvSymbol3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvPrice3"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvChange3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView  android:id="@+id/tvName"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- Row 1: [BTC icon] [SYMBOL/USD] [%change] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/circle_bg"
            android:src="@drawable/ic_btc"
            android:padding="4dp"
            android:scaleType="centerInside"/>

        <TextView
            android:id="@+id/tvSymbol"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="6dp"
            android:text="BTC/USD"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="14sp"/>

        <TextView
            android:id="@+id/tvChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7.43%"
            android:textColor="#10B981"
            android:textStyle="bold"
            android:textSize="12sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="14sp"/>
    </LinearLayout>

    <!-- Row 2: [Giant price (left)] [Sparkline (right)] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:gravity="center_vertical|start"
            android:text="0.00"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="44sp"/>

        <!-- Sparkline chart on the right -->
        <ImageView
            android:id="@+id/imgGraph"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"/>
    </LinearLayout>

    <!-- Row 3: [timestamp + refresh icon] [gear icon] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableStart="@drawable/ic_refresh"
            android:drawablePadding="3dp"
            android:text="10:59 pm"
            android:textColor="#606060"
            android:textSize="9sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="7sp"
            android:autoSizeMaxTextSize="11sp"/>

        <ImageView
            android:id="@+id/btnStars"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_stars"
            android:scaleType="centerInside"
            android:alpha="0.5"/>
    </LinearLayout>

</LinearLayout>
